# Production environment — copy to /var/www/qibla/.env on Contabo server

# Public site URL (required for SEO meta tags and robots.txt)
VITE_SITE_ORIGIN=https://yourdomain.com

# Admin panel password (required in production)
VITE_ADMIN_PASSWORD=your-secure-password-here

# Node server (optional — defaults shown)
PORT=3000
HOST=127.0.0.1
