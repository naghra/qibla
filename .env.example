# Public site URL (required for SEO meta tags and robots.txt)
VITE_SITE_ORIGIN=https://dacgateway.com

# Admin panel password (required in production)
VITE_ADMIN_PASSWORD=your-secure-password-here

# Server-side admin API auth (same value as VITE_ADMIN_PASSWORD)
ADMIN_PASSWORD=your-secure-password-here

# Node server (optional — defaults shown)
PORT=3000
HOST=127.0.0.1

# Stripe Checkout (required for live payments)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
