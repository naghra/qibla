# Copy to deploy/.env and edit before running deploy scripts

# Primary domain — Thailand travel site
SITE_DOMAIN=dacgateway.com
VITE_SITE_ORIGIN=https://dacgateway.com
VITE_ADMIN_PASSWORD=Ppassword@1
CERTBOT_EMAIL=admin@dacgateway.com

# Secondary domains (comma-separated, redirect to SITE_DOMAIN)
REDIRECT_DOMAINS=ksashort.shop,www.ksashort.shop

# Server
VPS_HOST=root@185.214.135.141
VPS_PATH=/var/www/qibla
APP_DIR=/opt/dacgateway
SSH_KEY=~/.ssh/qibla_deploy_ed25519

# PostgreSQL (Contabo VPS — port 5433, Supabase Docker uses 5432)
DB_NAME=dacgateway
DB_USER=dacgateway
DB_PASSWORD=change-me-strong-password
DB_PORT=5433
DATABASE_URL=postgresql://dacgateway:change-me-strong-password@127.0.0.1:5433/dacgateway

# Legacy Qibla deploy (deploy/deploy.sh only)
QIBLA_DOMAIN=ksashort.shop
